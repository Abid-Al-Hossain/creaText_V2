{
  "manifest_version": 3,
  "name": "CreaText",
  "description": "AI-powered text tools: summarize, translate, proofread, rewrite, and write — powered by Gemini.",
  "version": "1.0.0",
  "action": { "default_popup": "src/popup.html" },
  "background": { "service_worker": "src/bg.js", "type": "module" },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.jsx"],
      "run_at": "document_idle"
    }
  ]
}
